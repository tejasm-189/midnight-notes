#!/bin/sh
set -e

echo "=== Pre-commit Hook ==="

STAGED=$(git diff --cached --name-only 2>/dev/null || true)

# For each staged .rs file, check README.md + Test.md
RS_FILES=$(echo "$STAGED" | grep '\.rs$' 2>/dev/null || true)
echo "$RS_FILES" | while IFS= read -r rs_file; do
    [ -z "$rs_file" ] && continue
    dir=$(dirname "$rs_file")

    while [ "$dir" != "." ] && [ "$dir" != "/" ]; do
        readme="$dir/README.md"
        testmd="$dir/Test.md"

        if [ -f "$readme" ] && ! echo "$STAGED" | grep -qF "$readme"; then
            echo "WARNING: $readme is not staged — update it." >&2
        fi

        if [ -f "$testmd" ] && ! echo "$STAGED" | grep -qF "$testmd"; then
            echo "WARNING: $testmd is not staged — update it if tests changed." >&2
        fi

        parent=$(dirname "$dir")
        [ "$parent" = "$dir" ] && break
        dir="$parent"
    done
done

# Run quality checks
cargo check --quiet || { echo "ERROR: cargo check failed"; exit 1; }
cargo fmt -- --check --quiet || { echo "ERROR: cargo fmt failed — run 'cargo fmt'"; exit 1; }

echo "=== Pre-commit Passed ==="
