#!/bin/sh

echo "=== Midnight Notes: Documentation Enforcement ==="

# Get all files currently staged for commit
STAGED=$(git diff --cached --name-only)

# Identify if any Rust source files are being committed
RS_FILES=$(echo "$STAGED" | grep '\.rs$' || true)

if [ -n "$RS_FILES" ]; then
    echo "$RS_FILES" | while IFS= read -r rs_file; do
        [ -z "$rs_file" ] && continue
        
        # Start at the directory of the modified .rs file and walk up to the root
        dir=$(dirname "$rs_file")

        while [ "$dir" != "." ] && [ "$dir" != "/" ]; do
            readme="$dir/README.md"
            testmd="$dir/Test.md"

            # RULE: If a README.md exists in this hierarchy, it MUST be staged
            if [ -f "$readme" ]; then
                if ! echo "$STAGED" | grep -x -q "$readme"; then
                    echo "❌ ERROR: You modified '$rs_file'." >&2
                    echo "   You MUST update and stage '$readme' to document your changes." >&2
                    exit 1
                fi
            fi

            # RULE: If a Test.md exists in this hierarchy, it MUST be staged
            if [ -f "$testmd" ]; then
                if ! echo "$STAGED" | grep -x -q "$testmd"; then
                    echo "❌ ERROR: You modified '$rs_file'." >&2
                    echo "   You MUST update and stage '$testmd' to reflect test changes." >&2
                    exit 1
                fi
            fi

            parent=$(dirname "$dir")
            [ "$parent" = "$dir" ] && break
            dir="$parent"
        done
    done || exit 1 # Ensure the exit 1 from the subshell kills the script
fi

# Standard checks
cargo check --quiet || { echo "❌ ERROR: cargo check failed"; exit 1; }
cargo fmt -- --check --quiet || { echo "❌ ERROR: cargo fmt failed — run 'cargo fmt'"; exit 1; }

echo "✅ Pre-commit Passed: Documentation and code are in sync."
