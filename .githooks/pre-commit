#!/bin/sh
set -e

echo "=== Pre-commit Hook ==="

STAGED=$(git diff --cached --name-only 2>/dev/null || true)

# For each staged .rs file, check README.md + Test.md in its dir and all parent dirs
echo "$STAGED" | grep '\.rs$' 2>/dev/null || true | while IFS= read -r rs_file; do
    [ -z "$rs_file" ] && continue
    dir=$(dirname "$rs_file")

    while [ "$dir" != "." ] && [ "$dir" != "/" ]; do
        readme="$dir/README.md"
        testmd="$dir/Test.md"

        if [ -f "$readme" ] && git diff --name-only | grep -qF "$readme" 2>/dev/null && ! echo "$STAGED" | grep -qF "$readme"; then
            echo "ERROR: $readme has changes but is not staged — stage it." >&2
            exit 1
        fi

        if [ -f "$testmd" ] && git diff --name-only | grep -qF "$testmd" 2>/dev/null && ! echo "$STAGED" | grep -qF "$testmd"; then
            echo "ERROR: $testmd has changes but is not staged — stage it." >&2
            exit 1
        fi

        parent=$(dirname "$dir")
        [ "$parent" = "$dir" ] && break
        dir="$parent"
        [ ! -d "$dir" ] && break
    done
done

cargo check --quiet || { echo "ERROR: cargo check failed"; exit 1; }
cargo fmt -- --check --quiet || { echo "ERROR: cargo fmt failed — run 'cargo fmt'"; exit 1; }

echo "=== Pre-commit Passed ==="
